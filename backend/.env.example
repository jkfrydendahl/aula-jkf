# MitID credentials
AULA_MITID_USERNAME=your-mitid-username
AULA_MITID_PASSWORD=your-mitid-password
# Or use token-based auth:
# AULA_MITID_TOKEN=your-token
# AULA_AUTH_METHOD=APP

# VAPID keys (generate with: npx web-push generate-vapid-keys)
AULA_VAPID_PRIVATE_KEY=
AULA_VAPID_PUBLIC_KEY=
AULA_VAPID_CLAIM_EMAIL=your@email.com

# Polling interval (seconds)
AULA_POLL_INTERVAL=300

# Frontend URL for CORS
AULA_FRONTEND_URL=http://localhost:3000
