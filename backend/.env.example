# VAPID keys for push notifications (generate with: npx web-push generate-vapid-keys)
AULA_VAPID_PRIVATE_KEY=
AULA_VAPID_PUBLIC_KEY=
AULA_VAPID_CLAIM_EMAIL=your@email.com

# Polling interval (seconds)
AULA_POLL_INTERVAL=300

# Frontend URL for CORS (comma-separated for multiple origins)
AULA_FRONTEND_URL=http://localhost:3000

# Storage paths (defaults are fine for local dev)
# AULA_TOKEN_STORE_PATH=data/tokens.json
# AULA_PUSH_STORE_PATH=data/push_subs.json

# Token sync: shared secret to protect the token upload endpoint
# Set the SAME value on both local and Railway instances
AULA_ADMIN_SECRET=

# Token sync: remote backend URL (set on LOCAL instance only)
# After local MitID login, tokens are auto-pushed to this URL
# Example: https://aula-jkf-production.up.railway.app
AULA_SYNC_TARGET_URL=

# App-level authentication (PWA password gate)
APP_AUTH_ENABLED=true

# Backward-compatible single-user mode
APP_AUTH_PASSWORD=

# Multi-user mode
APP_USER_1_NAME=
APP_USER_1_PASSWORD=
APP_USER_1_TOKEN_PATH=/app/data/tokens_user1.json
APP_USER_1_PUSH_STORE_PATH=/app/data/push_subs_user1.json

APP_USER_2_NAME=
APP_USER_2_PASSWORD=
APP_USER_2_TOKEN_PATH=/app/data/tokens_user2.json
APP_USER_2_PUSH_STORE_PATH=/app/data/push_subs_user2.json

APP_SESSION_SECRET=
APP_SESSION_COOKIE_NAME=aula_jkf_session
APP_SESSION_TTL_SECONDS=604800
# Set to false when testing locally over HTTP (SSH tunnel). Must be true in production.
APP_SESSION_SECURE_COOKIE=true
